# API runtime
PORT=3000
DATABASE_URL=postgres://postgres:postgres@localhost:5432/event_notification_platform

# Redis / BullMQ
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# Retry defaults
DEFAULT_MAX_RETRY_LIMIT=3
RETRY_BASE_DELAY_MS=1000

# API access
PRODUCER_API_KEY=local-producer-key
ADMIN_API_KEY=local-admin-key

# Outbound webhook signing
WEBHOOK_SIGNING_SECRET_DEFAULT=local-webhook-signing-secret
